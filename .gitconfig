[user]
  name = David Sanchez
  email = d4vsanchez@gmail.com

[pull]
  rebase = true

[branch]
  autosetuprebase = always

[alias]
  b = checkout -b
  co = checkout
  cp = cherry-pick
  amend = commit -a --amend --no-edit

[push]
  default = current

[core]
  pager = delta 
  excludesfile = /home/d4vsanchez/.gitignore_global

[delta]
  navigate = true
  theme = 'gruvbox'

[interactive]
  diffFilter = delta --color-only

[color]
  ui = true

[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22

[color "diff"]
  meta = 11
  frag = magenta bold
  commit = yellow bold
  old = red bold
  new = green bold
  whitespace = red reverse

[init]
  defaultBranch = main
