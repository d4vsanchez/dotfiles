#!/usr/bin/env bash

DOTFILES_FOLDER="${HOME}/.dotfiles"
WORKSPACE_FOLDER="${HOME}/Workspace"

# Run without downloading:
# curl https://raw.githubusercontent.com/d4vsanchez/dotfiles/master/.macos | bash

# Close any open System Preferences panel, to prevent them from overriding
# settings we're about to change.
osascript -e 'tell application "System Preferences" to quit'

# Ask for the administrator password
sudo -v

echo "Hello $(whoami)! Let's start installing tools."

# Create the workspace folder
echo "✅ Create mkdir -p ${WORKSPACE_FOLDER}"
mkdir -p "${WORKSPACE_FOLDER}"

# Install Homebrew
echo "✅ Installing Homebrew"
CI=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"

echo "✅ Installing tools"
brew install git tig watchman tree zsh neovim tmux cmake direnv jq wget

echo "✅ Installing Rust coreutils alternatives"
brew install ripgrep bat bottom sd exa fd git-delta

echo "✅ Intalling Dev Fonts"
brew tap homebrew/cask-fonts
brew install --cask font-sauce-code-pro-nerd-font

echo "✅ Installing Oh My ZSH"
sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" --unattended

echo "✅ Installing apps with Brew cask"
brew install --cask \
  1password \
  discord \
  docker \
  firefox \
  keka \
  raycast \
  rectangle \
  slack \
  spotify \
  telegram \
  visual-studio-code \
  vlc \
  zoom

echo "✅ Cloning dotfiles"
if ! [ -d "$DOTFILES_FOLDER" ]; then
  git clone https://github.com/d4vsanchez/dotfiles.git "$DOTFILES_FOLDER"
fi

ln -sf "${HOME}/.dotfiles/.zshrc" "${HOME}/.zshrc"
ln -s "${HOME}/.dotfiles/.gitignore_global" "${HOME}/.gitignore_global"
ln -s "${HOME}/.dotfiles/.gitconfig" "${HOME}/.gitconfig"

source "${HOME}/.zshrc"

# Install asdf
echo "✅ Installing ASDF"
brew install asdf

# Configure asdf tools
echo "🛠 Configuring asdf tool versions"
ln -s "${HOME}/.dotfiles/.tool-versions" "${HOME}/.tool-versions"

# Install asdf tools
echo "✅ Installing asdf tools"
asdf install

export PATH=$PATH:$HOME/.asdf/shims

echo "ℹ️ Node installed: $(node --version)"
echo "ℹ️ NPM installed: $(npm --version)"

echo "✅ Installing a few global npm packages"
npm install --quiet npm yarn

echo "ℹ️ Python installed: $(python --version)"
pip install -U pip

echo "✅ Configuring bat"
mkdir -p "${HOME}/.config/bat/themes"
ln -sf "${HOME}/.dotfiles/.config/bat/config" "${HOME}/.config/bat/config"
bat cache --build

echo "✅ Configuring zsh"
ln -sf "${HOME}/.dotfiles/.oh-my-zsh/custom/themes/crush.zsh-theme" "${HOME}/.oh-my-zsh/custom/themes/crush.zsh-theme"
git clone https://github.com/mroth/evalcache $HOME/.oh-my-zsh/custom/plugins/evalcache

echo "✅ Configuring tmux"
ln -sf "${HOME}/.dotfiles/.tmux.conf" "${HOME}/.tmux.conf"

echo "✅ Configure Poetry"
curl -sSL https://install.python-poetry.org | python3 -

echo "Done. Note that some of these changes require a logout/restart to take effect."
